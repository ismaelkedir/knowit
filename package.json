{
  "name": "knowit",
  "version": "0.3.0",
  "description": "Shared team memory for AI coding agents — MCP server and CLI for persistent, queryable knowledge across sessions and teammates",
  "type": "module",
  "main": "dist/server/mcpServer.js",
  "bin": {
    "knowit": "dist/cli/index.js"
  },
  "files": [
    "dist/cli/",
    "dist/db/",
    "dist/install/",
    "dist/search/",
    "dist/server/",
    "dist/services/",
    "dist/sources/",
    "dist/storage/",
    "dist/types/",
    "dist/utils/",
    "!dist/tests/",
    "!dist/tests/**",
    "!dist/benchmark/",
    "!dist/benchmark/**",
    "!dist/cli/commands/benchmark*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server/mcpServer.js",
    "cli": "node dist/cli/index.js",
    "test": "npm run build && node --test dist/tests/**/*.test.js",
    "prune:package": "node scripts/prune-package-artifacts.mjs",
    "prepack": "npm run build && npm run prune:package",
    "pack:smoke": "npm pack --dry-run --cache /tmp/knowit-npm-cache",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "claude-code",
    "codex",
    "memory",
    "knowledge-base",
    "team-memory",
    "sqlite",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ismaelkedir/knowit.git"
  },
  "bugs": {
    "url": "https://github.com/ismaelkedir/knowit/issues"
  },
  "homepage": "https://useknowit.dev",
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.17.4",
    "better-sqlite3": "^11.10.0",
    "commander": "^14.0.0",
    "dotenv": "^16.6.1",
    "openai": "^6.1.0",
    "picocolors": "^1.1.1",
    "update-notifier": "^7.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.6.2",
    "typescript": "^5.9.3"
  }
}
